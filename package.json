{
	"name": "home-pantry",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev --host",
		"dev:watch": "nodemon --config nodemon.dev.json",
		"dev:health": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-runtime/health-check.ps1",
		"dev:start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-runtime/start-dev.ps1",
		"dev:start:ai": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-runtime/start-dev.ps1 -Worktree ai",
		"dev:start:admin": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-runtime/start-dev.ps1 -Worktree admin",
		"dev:start:tests": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-runtime/start-dev.ps1 -Worktree tests",
		"dev:https": "npx cross-env HTTPS=true vite dev --host",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"lint": "eslint .",
		"format": "prettier --write .",
		"test": "vitest run",
		"test:integration": "vitest run --config vitest.integration.config.ts",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio"
	},
	"devDependencies": {
		"@eslint/js": "^9.18.0",
		"@sveltejs/adapter-node": "^5.2.12",
		"@sveltejs/kit": "^2.16.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.3",
		"@types/node": "^22.10.7",
		"@vitejs/plugin-basic-ssl": "^2.3.0",
		"drizzle-kit": "^0.30.4",
		"eslint": "^9.18.0",
		"eslint-config-prettier": "^10.0.1",
		"eslint-plugin-svelte": "^2.46.1",
		"globals": "^15.14.0",
		"nodemon": "^3.1.14",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.3.3",
		"svelte": "^5.19.0",
		"svelte-check": "^4.1.4",
		"typescript": "^5.7.3",
		"typescript-eslint": "^8.20.0",
		"vite": "^6.0.7",
		"vitest": "^3.0.2"
	},
	"dependencies": {
		"@electric-sql/pglite": "^0.2.17",
		"@lucia-auth/adapter-drizzle": "^1.1.0",
		"@node-rs/argon2": "^2.0.2",
		"@zxing/browser": "^0.2.0",
		"drizzle-orm": "^0.39.1",
		"lucia": "^3.2.2",
		"postgres": "^3.4.5",
		"zod": "^3.24.1"
	}
}

# Local dev without Docker (no virtualization): use embedded Postgres
USE_PGLITE=true

# With Docker or installed PostgreSQL, set USE_PGLITE=false and:
# DATABASE_URL=postgresql://pantry:pantry@localhost:5432/pantry

# Canonical public URL (emails, marketing canonical/og:url, CSRF via ORIGIN in prod)
PUBLIC_ORIGIN=http://localhost:5173
# Marketing CTAs ? only when marketing and app are on different domains (optional)
# PUBLIC_APP_URL=https://home-pantry--home-pantry-4bee5.europe-west4.hosted.app
# adapter-node / SvelteKit CSRF for form actions when NODE_ENV=production
ORIGIN=http://localhost:3000
# Legacy hosted.app trusted for CSRF when ORIGIN is skaffu.com (see svelte.config.js; BUILD only)
# LEGACY_APP_ORIGIN=https://home-pantry--home-pantry-4bee5.europe-west4.hosted.app
PORT=3000
HOST=0.0.0.0
# adapter-node request body limit (default 512K); profile avatar uploads need ~1M after client resize
# BODY_SIZE_LIMIT=20M

# Public city feed at /delningar (W2 acquisition wedge) — enable only after manual seed check
# PUBLIC_CITY_FEED_ENABLED=true
# Minimum active geo shares before showing the feed (default 3)
# PUBLIC_CITY_FEED_MIN_SUPPLY=3

# OpenAI API key for generated recipe suggestions
OPENAI_API_KEY=
# Optional global monthly spend guardrail (USD estimate from ai_usage counts; blocks new AI when exceeded)
# OPENAI_MONTHLY_BUDGET_USD=25

# Default admin account (created/updated on each server start if ADMIN_PASSWORD is set)
ADMIN_EMAIL=arvid.pilhall@me.com
ADMIN_PASSWORD=change-me

# --- Playwright E2E (copy these for local `npm run test:e2e`) ---
# Playwright overrides ADMIN_* via playwright.config.ts when unset; set explicitly to match CI:
# USE_PGLITE=true
# ADMIN_EMAIL=e2e-admin@example.com
# ADMIN_PASSWORD=e2e-ci-password
# PUBLIC_ORIGIN=http://localhost:5173
# TURNSTILE_SKIP=true
# TURNSTILE_BYPASS=true
# EMAIL_VERIFICATION_SKIP=true
# E2E_MOCK_AI=true
# OPENAI_API_KEY is NOT required for E2E (receipt/barcode mocked in browser; smart fill uses fixture)

# Optional overrides for Playwright (defaults to ADMIN_* above, then e2e-ci-password in CI)
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=
# E2E_USER_PASSWORD=e2e-test-password-9

# Resend (household invite email) ? see docs/EMAIL.md
RESEND_API_KEY=
RESEND_FROM=Skaffu <onboarding@resend.dev>
# Resend Inbound webhook signing secret (Kivra forward beta)
# RESEND_WEBHOOK_SECRET=

# Kivra forward beta — POST /api/inbound/kivra (see docs/KIVRA_FORWARD_SPIKE.md)
# KIVRA_FORWARD_ENABLED=true
# Public read-only shopping list share (W1 acquisition wedge). Prod: apphosting.yaml sets true (BUILD+RUNTIME).
# PUBLIC_SHOPPING_LIST_SHARE_ENABLED=true
# KIVRA_FORWARD_DOMAIN=inbound.skaffu.com
# KIVRA_FORWARD_SECRET=  # optional; defaults to CRON_SECRET for token derivation
# After skaffu.com is Verified in Resend (docs/EMAIL.md) ? do NOT use until domain Connected:
# RESEND_FROM=Skaffu <hello@skaffu.com>
# Global kill switch ? when true, no email is sent (App Hosting sets this until domain is verified)
EMAIL_SENDING_DISABLED=true

# Cron routes ? POST /api/cron/* with Authorization: Bearer <secret>
# expiry-reminders (Mon 07:00 UTC), pmf-weekly (Mon 08:00), error-alert (every 30 min),
# shopping-push (daily 06:00), skaffurapport (1st of month 06:00 UTC) ? see .github/workflows/*-cron.yml
CRON_SECRET=

# Weekly PMF digest to owner ? POST /api/cron/pmf-weekly (bypasses EMAIL_SENDING_DISABLED)
PMF_DIGEST_TO=arvid.pilhall@me.com

# Prod error alert email ? POST /api/cron/error-alert every 30 min (falls back to PMF_DIGEST_TO)
# ERROR_ALERT_TO=arvid.pilhall@me.com

# Web Push (PWA) ? generate with: npx web-push generate-vapid-keys
PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Optional VAPID subject (defaults to PUBLIC_ORIGIN or mailto:support@homepantry.com)
# VAPID_CONTACT=mailto:support@homepantry.com


# Google OAuth (Sign in with Google) ? Console redirect URI: {PUBLIC_ORIGIN}/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# LinkedIn Company Page API ? see docs/LINKEDIN_COMPANY_PAGE.md
# Redirect URI: {PUBLIC_ORIGIN}/api/linkedin/callback
# Requires w_organization_social scope approval from LinkedIn Developer Portal
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ORGANIZATION_ID=
# Cloudflare Turnstile (registration CAPTCHA) ? see docs/CAPTCHA.md
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# Cloudflare test mode (always pass, any domain) ? optional for manual register testing:
# PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
# TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
# Local dev without Turnstile (ignored in production):
# TURNSTILE_SKIP=true
# TURNSTILE_BYPASS=true

# Default household member (shared inventory demo user; created on startup if missing)
DEFAULT_MEMBER_EMAIL=amanda.derborn@hotmail.com
DEFAULT_MEMBER_PASSWORD=change-me
# Aliases: AMANDA_EMAIL / AMANDA_PASSWORD

# Sales demo account ? see docs/DEMO_ACCOUNT.md
# DEMO_ACCOUNT_EMAIL=demo@skaffu.com
# DEMO_ACCOUNT_PASSWORD=choose-a-strong-demo-password
# Optional nightly reset: POST /api/cron/reset-demo with Authorization: Bearer $CRON_SECRET

# --- Stripe (Pro checkout, TEST mode first) ? see docs/STRIPE.md ---
# Dashboard ? Developers ? API keys (test mode)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs from Products ? Pro (monthly 39 SEK / yearly 299 SEK)
STRIPE_PRICE_ID_MONTHLY=price_1TdyEW0xHxoOfEfBbbfRVfJp
STRIPE_PRICE_ID_YEARLY=price_1TdyFt0xHxoOfEfBd160VXF3
# Hard kill switch for Pro checkout (admin toggle in /admin still required)
STRIPE_CHECKOUT_DISABLED=true
# Emergency kill-switch for Grannskafferiet Market v0.1 (cron auto-listing + /grannskafferiet/marknad)
# MARKET_V01_DISABLED=true
# --- Cloud SQL (project home-pantry-4bee5) ? local migrate via public IP ---
# 1. GCP Console ? Cloud SQL ? home-pantry-4bee5-instance ? Connections ? Authorized networks ? add your IP
# 2. Copy this block into .env (replace YOUR_PASSWORD; never commit .env):
# USE_PGLITE=false
# DATABASE_URL=postgresql://pantry_app:YOUR_PASSWORD@34.158.71.215:5432/pantry
# Then: npm run db:migrate

# --- Cloud SQL ? Firebase App Hosting (Unix socket, set as secret) ---
# npx firebase apphosting:secrets:set DATABASE_URL --project home-pantry-4bee5
# Secret value (replace YOUR_PASSWORD):
# postgresql://pantry_app:YOUR_PASSWORD@/pantry?host=/cloudsql/home-pantry-4bee5:europe-west4:home-pantry-4bee5-instance

# --- Production (Firebase App Hosting / Cloud Run) ---
# USE_PGLITE=false
# Current production URL (skaffu.com ? see docs/SKAFFU_DOMAIN_MIGRATION.md):
# PUBLIC_ORIGIN=https://skaffu.com
# ORIGIN=https://skaffu.com
# Leave PUBLIC_APP_URL unset ? marketing and app share the same origin.
# Legacy hosted.app (still works during transition):
# PUBLIC_ORIGIN=https://home-pantry--home-pantry-4bee5.europe-west4.hosted.app
# ORIGIN=https://home-pantry--home-pantry-4bee5.europe-west4.hosted.app
# NODE_ENV=production
# Set secrets via: npx firebase apphosting:secrets:set DATABASE_URL
# See docs/FIREBASE_DEPLOY.md

# --- GitHub Actions only (not .env) ? optional deploy push notification ---
# DEPLOY_NOTIFY_WEBHOOK_URL=https://ntfy.sh/your-secret-topic   # or Discord/Slack webhook
# DEPLOY_TELEGRAM_BOT_TOKEN=                                     # alternative to webhook
# DEPLOY_TELEGRAM_CHAT_ID=

# --- Brain V1 (local dev — on by default; set *_ENABLED=false to disable) ---
# SHELF_LIFE_LEARNING_ENABLED=false
# Brain v2 kill switches (default: learning + rank + briefing on; auto-finish off)
# RECEIPT_AI_BATCH_ENABLED=false
# GLOBAL_SHELF_LIFE_DB_ENABLED=false
# AUTO_FINISH_ENABLED=true
# PUBLIC_SHELF_LIFE_ESTIMATES_IN_RECEIPT=true
# LOCATION_LEARNING_ENABLED=false
# REPLENISHMENT_LEARNING_ENABLED=false
# BRAIN_FEEDBACK_V1_ENABLED=false
# SHOPPING_UX_V2_ENABLED=true
# PANTRY_UX_V2_ENABLED=true
# HOME_UX_V2_ENABLED=false
# PHOTO_VALIDATION_ENABLED=false
# HOME_BRIEFING_AI_ENABLED=false
# REPLENISHMENT_RANK_ENABLED=false
# BRAIN_PROACTIVE_ENABLED=false
# STORE_RECOMMENDATION_V0_ENABLED=true

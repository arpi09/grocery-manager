# Local dev without Docker (no virtualization): use embedded Postgres
USE_PGLITE=true

# With Docker or installed PostgreSQL, set USE_PGLITE=false and:
# DATABASE_URL=postgresql://pantry:pantry@localhost:5432/pantry

# Canonical public URL (emails, marketing canonical/og:url, CSRF via ORIGIN in prod)
PUBLIC_ORIGIN=http://localhost:5173
# Marketing CTAs ‚Äî only when marketing and app are on different domains (optional)
# PUBLIC_APP_URL=https://home-pantry--home-pantry-4bee5.europe-west4.hosted.app
# adapter-node / SvelteKit CSRF for form actions when NODE_ENV=production
ORIGIN=http://localhost:3000
# Legacy hosted.app trusted for CSRF when ORIGIN is skaffu.com (see svelte.config.js; BUILD only)
# LEGACY_APP_ORIGIN=https://home-pantry--home-pantry-4bee5.europe-west4.hosted.app
PORT=3000
HOST=0.0.0.0
# adapter-node request body limit (default 512K); profile avatar uploads need ~1M after client resize
# BODY_SIZE_LIMIT=1M

# OpenAI API key for generated recipe suggestions
OPENAI_API_KEY=
# Optional global monthly spend guardrail (USD estimate from ai_usage counts; blocks new AI when exceeded)
# OPENAI_MONTHLY_BUDGET_USD=25

# Default admin account (created/updated on each server start if ADMIN_PASSWORD is set)
ADMIN_EMAIL=arvid.pilhall@me.com
ADMIN_PASSWORD=change-me

# --- Playwright E2E (copy these for local `npm run test:e2e`) ---
# Playwright overrides ADMIN_* via playwright.config.ts when unset; set explicitly to match CI:
# USE_PGLITE=true
# ADMIN_EMAIL=e2e-admin@example.com
# ADMIN_PASSWORD=e2e-ci-password
# PUBLIC_ORIGIN=http://localhost:5173
# TURNSTILE_SKIP=true
# TURNSTILE_BYPASS=true
# E2E_MOCK_AI=true
# OPENAI_API_KEY is NOT required for E2E (receipt/barcode mocked in browser; smart fill uses fixture)

# Optional overrides for Playwright (defaults to ADMIN_* above, then e2e-ci-password in CI)
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=
# E2E_USER_PASSWORD=e2e-test-password-9

# Resend (household invite email) ‚Äî see docs/EMAIL.md
RESEND_API_KEY=
RESEND_FROM=Skaffu <onboarding@resend.dev>
# After skaffu.com is Verified in Resend (docs/EMAIL.md) ‚Äî do NOT use until domain Connected:
# RESEND_FROM=Skaffu <hello@skaffu.com>
# Global kill switch ‚Äî when true, no email is sent (App Hosting sets this until domain is verified)
EMAIL_SENDING_DISABLED=true

# Weekly expiry reminder cron ‚Äî POST /api/cron/expiry-reminders with Authorization: Bearer <secret>
# Sends email (opt-in) and browser push (opt-in) on the same schedule.
CRON_SECRET=

# Weekly PMF digest to owner ‚Äî POST /api/cron/pmf-weekly (bypasses EMAIL_SENDING_DISABLED)
PMF_DIGEST_TO=arvid.pilhall@me.com

# Web Push (PWA) ‚Äî generate with: npx web-push generate-vapid-keys
PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Optional VAPID subject (defaults to PUBLIC_ORIGIN or mailto:support@homepantry.com)
# VAPID_CONTACT=mailto:support@homepantry.com


# Google OAuth (Sign in with Google) ó Console redirect URI: {PUBLIC_ORIGIN}/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Cloudflare Turnstile (registration CAPTCHA) ‚Äî see docs/CAPTCHA.md
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# Cloudflare test mode (always pass, any domain) ‚Äî optional for manual register testing:
# PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
# TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
# Local dev without Turnstile (ignored in production):
# TURNSTILE_SKIP=true
# TURNSTILE_BYPASS=true

# Default household member (shared inventory demo user; created on startup if missing)
DEFAULT_MEMBER_EMAIL=amanda.derborn@hotmail.com
DEFAULT_MEMBER_PASSWORD=change-me
# Aliases: AMANDA_EMAIL / AMANDA_PASSWORD

# Sales demo account ‚Äî see docs/DEMO_ACCOUNT.md
# DEMO_ACCOUNT_EMAIL=demo@skaffu.com
# DEMO_ACCOUNT_PASSWORD=choose-a-strong-demo-password
# Optional nightly reset: POST /api/cron/reset-demo with Authorization: Bearer $CRON_SECRET

# --- Cloud SQL (project home-pantry-4bee5) ‚Äî local migrate via public IP ---
# 1. GCP Console ‚Üí Cloud SQL ‚Üí home-pantry-4bee5-instance ‚Üí Connections ‚Üí Authorized networks ‚Üí add your IP
# 2. Copy this block into .env (replace YOUR_PASSWORD; never commit .env):
# USE_PGLITE=false
# DATABASE_URL=postgresql://pantry_app:YOUR_PASSWORD@34.158.71.215:5432/pantry
# Then: npm run db:migrate

# --- Cloud SQL ‚Äî Firebase App Hosting (Unix socket, set as secret) ---
# npx firebase apphosting:secrets:set DATABASE_URL --project home-pantry-4bee5
# Secret value (replace YOUR_PASSWORD):
# postgresql://pantry_app:YOUR_PASSWORD@/pantry?host=/cloudsql/home-pantry-4bee5:europe-west4:home-pantry-4bee5-instance

# --- Production (Firebase App Hosting / Cloud Run) ---
# USE_PGLITE=false
# Current production URL (skaffu.com ‚Äî see docs/SKAFFU_DOMAIN_MIGRATION.md):
# PUBLIC_ORIGIN=https://skaffu.com
# ORIGIN=https://skaffu.com
# Leave PUBLIC_APP_URL unset ‚Äî marketing and app share the same origin.
# Legacy hosted.app (still works during transition):
# PUBLIC_ORIGIN=https://home-pantry--home-pantry-4bee5.europe-west4.hosted.app
# ORIGIN=https://home-pantry--home-pantry-4bee5.europe-west4.hosted.app
# NODE_ENV=production
# Set secrets via: npx firebase apphosting:secrets:set DATABASE_URL
# See docs/FIREBASE_DEPLOY.md
